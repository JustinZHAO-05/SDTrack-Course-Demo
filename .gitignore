# Python/runtime
.venv/
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Local secrets and transient downloads
.env
.env.*
*.part
*.tmp
*.bak

# Course/private planning materials not required for public reproduction
